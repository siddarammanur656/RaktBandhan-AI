# RaktBandhan AI — Environment Variables Template
# Copy this file to .env.local (frontend) or .env (backend) and fill in actual values
# NEVER commit .env files to git

# =========================================
# FRONTEND ENVIRONMENT VARIABLES (Vite)
# Place in: frontend/.env.local
# =========================================

# API Gateway URL (from AWS API Gateway)
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# AWS Cognito Configuration
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXX
VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx

# App Settings
VITE_APP_NAME=RaktBandhan AI
VITE_APP_VERSION=1.0.0


# =========================================
# BACKEND ENVIRONMENT VARIABLES (Lambda)
# Place in: backend/.env
# Also set these as Lambda environment variables
# =========================================

# AWS Region (mandatory)
AWS_REGION=us-east-1

# DynamoDB Table Names
USERS_TABLE=rb_users
REQUESTS_TABLE=rb_requests
DONATIONS_TABLE=rb_donations
CONVERSATIONS_TABLE=rb_conversations
SCHEDULES_TABLE=rb_schedules
FAILURE_LOGS_TABLE=rb_failure_logs

# S3 Buckets
S3_DATA_BUCKET=raktbandhan-data-yourteam
S3_ML_BUCKET=raktbandhan-ml-yourteam

# Amazon SES (Email)
SES_SENDER_EMAIL=noreply@raktbandhan.ai
SES_SENDER_NAME=RaktBandhan AI

# Amazon Bedrock Models
BEDROCK_MODEL_HAIKU=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MODEL_SONNET=anthropic.claude-3-5-sonnet-20240620-v1:0

# Amazon Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx

# Step Functions ARN (created after Step Functions setup)
OUTREACH_STATE_MACHINE_ARN=arn:aws:states:us-east-1:ACCOUNT:stateMachine:rb-outreach-workflow

# EventBridge
EVENTBRIDGE_SCHEDULE_GROUP=default
EVENTBRIDGE_ROLE_ARN=arn:aws:iam::ACCOUNT:role/raktbandhan-eventbridge-role

# SageMaker (if using)
SAGEMAKER_CHURN_ENDPOINT=rb-churn-endpoint

# Application Settings
DEFAULT_OUTREACH_BATCH_SIZE=5
ESCALATION_WAIT_MINUTES=30
MAX_DONOR_DISTANCE_KM=50
RELIABILITY_SCORE_REFRESH_DAYS=7


# =========================================
# LOCAL DEVELOPMENT (Optional)
# For testing Lambda functions locally
# =========================================

# AWS Credentials (use AWS CLI configure instead)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Local Server Port
LOCAL_PORT=8000


# =========================================
# DEMO ACCOUNTS (For Testing)
# These get created via load_data.py
# =========================================

DEMO_ADMIN_EMAIL=admin@raktbandhan.ai
DEMO_DONOR_EMAIL=rahul.gold@demo.com
DEMO_PATIENT_EMAIL=anjali.patient@demo.com
DEMO_PASSWORD=Demo2024!


# =========================================
# NOTES
# =========================================
# 1. Replace all placeholder values (XXXXXXX, ACCOUNT, etc.)
# 2. Add .env to .gitignore (NEVER commit secrets)
# 3. Set Lambda env vars in AWS Console for production
# 4. Use AWS Secrets Manager for sensitive production secrets
# 5. Frontend vars must start with VITE_ to be exposed to browser
